    cards.pack(fill=X, pady=20)

    def info_card(parent, title, value):
        card = Frame(parent, bg="#1f2933", width=300, height=600)
        card.pack(side=LEFT, padx=10)
        Label(card, text=title,
              fg="#9ca3af", bg="#1f2933",
              font=("Arial", 12, "bold")).pack(pady=10)
        Label(card, text=value,
              fg="#4ade80", bg="#1f2933",
              font=("Arial", 22, "bold")).pack()

    info_card(cards, "Total Products", get_total_products())
    info_card(cards, "Total Buy", f"₹ {get_total_buy():.2f}")

    # -------- BOTTOM PANELS --------
    bottom = Frame(content, bg="#121212")
    bottom.pack(fill=BOTH, expand=True)

    # Latest Store
    store_frame = Frame(bottom, bg="#1f2933")
    store_frame.pack(side=LEFT, fill=BOTH, expand=True, padx=10)

    Label(store_frame, text="Latest Store",
          fg="white", bg="#1f2933",
          font=("Arial", 14, "bold")).pack(anchor="w", padx=10, pady=10)

    for p, q, pr in get_latest_store():
        Label(store_frame,
              text=f"{p} | Qty: {q} | ₹{pr}",
              fg="#d1d5db", bg="#1f2933",
          font=("Arial", 14)).pack(anchor="w", padx=20)

    # Latest Spend
    spend_frame = Frame(bottom, bg="#1f2933")
    spend_frame.pack(side=LEFT, fill=BOTH, expand=True, padx=10)

    Label(spend_frame, text="Latest Spend",
          fg="white", bg="#1f2933",
          font=("Arial", 14, "bold")).pack(anchor="w", padx=10, pady=10)

    for name, q, grand in get_latest_bill():
        Label(spend_frame,
              text=f"{name} | Qty: {q} | ₹{grand}",
              fg="#d1d5db", bg="#1f2933",font=("Arial", 14)).pack(anchor="w", padx=20)

# DASHBOARD DATA
def get_total_products():
    db = stock_db()
    cur = db.cursor()
    cur.execute("SELECT COUNT(*) FROM stock")
    return cur.fetchone()[0]

def get_total_buy():
    db = stock_db()
    cur = db.cursor()
    try:
        cur.execute("SELECT SUM(total) FROM invoices")
        val = cur.fetchone()[0]
        return val if val else 0
    except:
        return 0

def get_latest_bill():
    db = stock_db()
    cur = db.cursor()
    cur.execute("SELECT customer,quantity,total FROM invoices ORDER BY id DESC LIMIT 5")
    return cur.fetchall()

def get_latest_store():
    db = stock_db()
    cur = db.cursor()
    cur.execute("SELECT product_name, quantity, price FROM stock ORDER BY product_id DESC LIMIT 5")
    return cur.fetchall()

