#LOGIN MODULE
def show_login(root):
    login_window = Toplevel(root)
    login_window.title("Login")
    login_window.geometry("400x300")
    login_window.configure(bg="#121212")

    def check_login():
        user = username_entry.get()
        pwd = password_entry.get()

        if user == "admin" and pwd == " ":
            login_window.destroy()
            root.deiconify()   # show main window
        else:
            messagebox.showerror("Error", "Invalid login")

    # Close app completely if login window is closed
    def close_app():
        root.destroy()

    login_window.protocol("WM_DELETE_WINDOW", close_app)

    # Main frame
    frame = Frame(login_window, bg="#1f2933", padx=30, pady=30)
    frame.place(relx=0.5, rely=0.5, anchor=CENTER)

    # Title
    Label(frame, text="Login",
          font=("Arial", 18, "bold"),
          fg="white", bg="#1f2933").grid(row=0, column=0, columnspan=2, pady=10)

    # Username
    Label(frame, text="Username",
          fg="white", bg="#1f2933").grid(row=1, column=0, sticky="w", pady=5)

    username_entry = Entry(frame, bg="#121212", fg="white", insertbackground="white")
    username_entry.grid(row=1, column=1, pady=5)

    # Password
    Label(frame, text="Password",
          fg="white", bg="#1f2933").grid(row=2, column=0, sticky="w", pady=5)

    password_entry = Entry(frame, show="*", bg="#121212", fg="white", insertbackground="white")
    password_entry.grid(row=2, column=1, pady=5)

    # Login Button
    Button(frame, text="Login",
           command=check_login,
           bg="#4ade80", fg="black",
           activebackground="#22c55e",
           relief=FLAT, padx=10, pady=5).grid(row=3, column=0, columnspan=2, pady=15)

